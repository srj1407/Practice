{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
    "name":"Task Breakdown schema",
    "type":"object",
    "properties":{
      "goal":{
        "description":"Goal Name",
        "type":"string"
      },
      "steps":{
        "description":"Description of steps",
        "type":"array",
        "items":{
          "type":"object",
          "properties":{
            "step":{
              "description":"Step number",
              "type":"integer"
            },
            "action":{
              "description":"Description of step to be performed",
              "type":"string"
            }
          },
          "required": [ "step", "action"]
        },
        "minItems":1
      },
      "estimated_time":{
        "description":"Estimated time taken to achieve the goal"
      }
    },
    "required": [ "goal"]
}